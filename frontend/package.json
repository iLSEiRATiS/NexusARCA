{
  "name": "mascolo-quimicos-facturador-frontend",
  "private": true,
  "version": "1.0.0",
  "main": "electron.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "build:frontend": "tsc -b && vite build",
    "build:backend": "cd ../backend && npm run build && xcopy /E /I /Y dist ..\\frontend\\backend-dist",
    "prep:prisma": "copy ..\\backend\\prisma\\schema.prisma .\\backend-dist\\schema.prisma && xcopy /E /I /Y ..\\backend\\node_modules\\@prisma\\client .\\node_modules\\@prisma\\client && xcopy /E /I /Y ..\\backend\\node_modules\\.prisma .\\node_modules\\.prisma",
    "dist": "npm run build:frontend && npm run build:backend && npm run prep:prisma && electron-builder --win dir",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.mascolo.facturador",
    "productName": "Mascolo Facturador",
    "forceCodeSigning": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "backend-dist/**/*",
      "electron.cjs",
      "package.json",
      "node_modules/@prisma/client/**/*",
      "node_modules/.prisma/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": "public/favicon.svg"
    },
    "extraResources": [
      {
        "from": "../backend/prisma/dev.db",
        "to": "data/dev.db"
      }
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.16.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.16.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-is-dev": "^3.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
