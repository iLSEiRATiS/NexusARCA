generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum MovementType {
  INGRESO
  EGRESO
  AJUSTE
}

enum CondicionIva {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTO
  EXENTO
  CONSUMIDOR_FINAL
}

// --- MODELOS ---

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   
  nombre    String
  role      String   @default("ADMIN") 
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id           Int             @id @default(autoincrement())
  nombre       String
  presentacion String?         
  peso_kg      Decimal         @default(25.00) 
  precio_usd   Decimal         @default(0) // Precio base sugerido
  precio_ars   Decimal         @default(0) // Precio base sugerido en pesos
  moneda_base  String          @default("USD") // USD o ARS
  iva_tasa     Decimal         @default(21.00) 
  stock_actual Int             @default(0)
  stock_minimo Int             @default(5)
  batches      Batch[]
  saleItems    SaleItem[]
  quotationItems QuotationItem[]
  movements    StockMovement[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Batch {
  id                Int           @id @default(autoincrement())
  product           Product       @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id        Int
  nro_lote          String
  cantidad_bultos   Int
  fecha_vencimiento DateTime?
  ubicacion         String?
  estado            String        @default("ACTIVO") 
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  saleItems         SaleItem[]
}

model Client {
  id                      Int          @id @default(autoincrement())
  external_id             Int?         @unique 
  razon_social            String
  cuit                    String       @unique
  direccion               String?
  condicion_iva           CondicionIva @default(RESPONSABLE_INSCRIPTO)
  nro_iibb                String?      
  telefono                String?
  
  saldo_blanco            Decimal      @default(0) 
  saldo_negro             Decimal      @default(0) 
  saldo_deuda             Decimal      @default(0) 
  
  porcentaje_facturacion  Decimal      @default(100.00) 
  sales                   Sale[]
  payments                Payment[]
  quotations              Quotation[]
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

model Quotation {
  id                     Int             @id @default(autoincrement())
  client                 Client          @relation(fields: [client_id], references: [id], onDelete: Cascade)
  client_id              Int
  fecha                  DateTime        @default(now())
  validez_dias           Int             @default(15)
  estado                 String          @default("PENDIENTE") 
  
  total_real_ars         Decimal
  cotizacion_dolar_usada Decimal
  
  items                  QuotationItem[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
}

model QuotationItem {
  id                  Int       @id @default(autoincrement())
  quotation           Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  quotation_id        Int
  product             Product   @relation(fields: [product_id], references: [id], onDelete: Restrict)
  product_id          Int
  cantidad            Int
  precio_unitario_ars Decimal
  precio_unitario_usd Decimal
}

model Sale {
  id                     Int           @id @default(autoincrement())
  external_id            Int?          @unique 
  client                 Client        @relation(fields: [client_id], references: [id], onDelete: Restrict)
  client_id              Int
  fecha                  DateTime      @default(now())
  
  total_real_ars         Decimal        
  cotizacion_dolar_usada Decimal       
  
  monto_facturado_ars    Decimal        
  monto_no_facturado_ars Decimal        
  porcentaje_split       Decimal         

  subtotal_ars           Decimal       
  iva_ars                Decimal       
  estado_factura         String        @default("PENDIENTE")
  tipo_comprobante       String        
  nro_comprobante        String?       @unique
  cae                    String?
  vto_cae                DateTime?
  
  items                  SaleItem[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

model SaleItem {
  id                  Int     @id @default(autoincrement())
  sale                Sale    @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  sale_id             Int
  product             Product @relation(fields: [product_id], references: [id], onDelete: Restrict)
  product_id          Int
  batch               Batch?  @relation(fields: [batch_id], references: [id], onDelete: SetNull)
  batch_id            Int?
  cantidad            Int     
  precio_unitario_ars Decimal 
  iva_tasa            Decimal   
  precio_unitario_usd Decimal  
}

model Payment {
  id          Int        @id @default(autoincrement())
  client      Client     @relation(fields: [client_id], references: [id], onDelete: Restrict)
  client_id   Int
  monto_ars   Decimal    
  tipo        String     @default("MIXTO") 
  metodo_pago String     @default("TRANSFERENCIA")
  referencia  String?    
  fecha       DateTime   @default(now())
  createdAt   DateTime   @default(now())
}

model StockMovement {
  id         Int          @id @default(autoincrement())
  product    Product      @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id Int
  cantidad   Int          
  tipo       MovementType
  motivo     String?      
  fecha      DateTime     @default(now())
}

model Settings {
  id                      Int      @id @default(1)
  cotizacion_dolar_actual Decimal  
  updatedAt               DateTime @updatedAt
}
